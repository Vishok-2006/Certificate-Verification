NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
PUBLIC_VERIFY_BASE_URL=http://localhost:5173/verify
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=replace-with-a-long-secret
JWT_EXPIRES_IN=1d
ENCRYPTION_KEY=replace-with-a-32-byte-secret
ADMIN_REGISTRATION_KEY=replace-with-admin-bootstrap-key

DB_DIALECT=postgres
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/certiblock
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=certiblock
DB_SSL=false

RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=replace-with-wallet-private-key
CONTRACT_ADDRESS=replace-with-sepolia-contract-address
POLYGON_CONTRACT_ADDRESS=replace-with-polygon-contract-address
DEFAULT_CHAIN=sepolia
EXPLORER_BASE_URL=https://sepolia.etherscan.io
POLYGON_EXPLORER_BASE_URL=https://amoy.polygonscan.com

PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
WEB3_STORAGE_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@certiblock.local
SMTP_SECURE=false

MAX_UPLOAD_SIZE_MB=10
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_MAX=120
VERIFICATION_RATE_LIMIT_MAX=60
